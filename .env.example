# =============================================================
# Swarm Factory — Environment Variables
# =============================================================
# REQUIRED fields (marked with [REQUIRED]) will cause startup
# failure if missing. Everything else has a working default.
# =============================================================

# ── TIER 1: Azure OpenAI (primary — required for full stack) ──
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/   # [REQUIRED]
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here             # [REQUIRED]
AZURE_OPENAI_API_VERSION=2024-02-01

# Deployment names (must match your Azure deployments exactly)
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o
AZURE_OPENAI_DEPLOYMENT_PHI4=phi-4
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-4o-mini

# ── TIER 2: Free fallback models (at least one recommended) ───
# Groq (Llama-3.3-70b + Mixtral-8x7b) — https://console.groq.com/keys
# Free: 14,400 req/day
GROQ_API_KEY=your-groq-api-key-here

# Gemini Flash — https://aistudio.google.com/apikey
# Free: 15 req/min, 1M tokens/day
GEMINI_API_KEY=your-gemini-api-key-here

# Cohere Command-R — https://dashboard.cohere.com/api-keys
# Free: 1,000 calls/month
COHERE_API_KEY=your-cohere-api-key-here

# Mistral via OpenRouter — https://openrouter.ai/keys
# Free tier available for Mistral-7B
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── Fallback chain model names ─────────────────────────────────
# Maps to the Azure deployment names above — change only if you
# renamed your deployments in Azure Portal
FALLBACK_MODEL_PRIMARY=gpt-4o
FALLBACK_MODEL_SECONDARY=phi-4
FALLBACK_MODEL_TERTIARY=gpt-4o-mini

# ── Redis / Celery ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0                               # [REQUIRED]

# ── Security ───────────────────────────────────────────────────
API_KEY=swarm-factory-dev-key                                    # [REQUIRED]
SECRET_KEY=swarm-factory-secret-key-minimum-32-chars!!           # [REQUIRED]

# ── Azure AI Search (vector memory) ───────────────────────────
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-azure-search-api-key-here
AZURE_SEARCH_INDEX_NAME=swarm-memory

# ── Azure Container Apps (needed for DevOps agent deploy) ─────
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_RESOURCE_GROUP=swarm-factory-rg
AZURE_CONTAINER_REGISTRY=yourregistry.azurecr.io
AZURE_CONTAINER_APP_ENV=swarm-factory-env

# ── GitHub (needed to push generated repos) ───────────────────
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_ORG=your-github-username-or-org

# ── Bing Search (optional — web_search tool) ──────────────────
BING_SEARCH_API_KEY=your-bing-search-api-key-here

# ── Application tunables ───────────────────────────────────────
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR | CRITICAL
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_SECONDS=600
SESSION_STORE_PATH=./sessions

# ── Rate limiting ──────────────────────────────────────────────
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# ── Frontend (used by Vite — prefix must be VITE_) ─────────────
# NOTE: These go in frontend/.env, NOT the root .env
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
VITE_API_KEY=swarm-factory-dev-key